# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_bot_token_here

# TMDB API Token (Read Access Token from https://www.themoviedb.org/settings/api)
# Use the "API Read Access Token (v4 auth)", not the API Key v3!
TMDB_API_TOKEN=your_tmdb_read_access_token_here

# PostgreSQL connection string
# Railway provides this automatically as DATABASE_URL
DATABASE_URL=postgresql://user:password@host:5432/dbname
